{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["ESNext", "DOM"],
    "types": ["node", "vite/client"],
    "module": "ESNext",
    "skipLibCheck": true,

    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",

    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    "baseUrl": ".",
    "paths": {
      "/src/*": ["src/*"],
      "@kit": ["packages/ajo-kit/src/constants.ts"],
      "@kit/auth/*": ["packages/ajo-auth/src/*"],
      "@kit/*": ["packages/ajo-kit/src/*"],
    },
  },
}
