{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["ESNext", "DOM"],
    "types": ["node", "vite/client"],
    "module": "ESNext",
    "skipLibCheck": true,

    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "jsxImportSource": "ajo",

    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    "paths": {
      "/src/*": ["./src/*"],
      "@kit": ["./packages/ajo-kit/src/constants.ts"],
      "@kit/auth": ["./packages/ajo-auth/src/index.ts"],
      "@kit/*": ["./packages/ajo-kit/src/*"],
    },
  },
}
