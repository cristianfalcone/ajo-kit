{
  "type": "module",
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3"]
  },
  "scripts": {
    "dev": "tsx watch --include 'src/**/handler.ts' --include 'src/**/wares.ts' --include 'src/server.tsx' server.ts dev",
    "build": "pnpm build:client && pnpm build:server",
    "build:client": "vite build --outDir dist/client",
    "build:server": "vite build --ssr src/server.tsx --outDir dist/server",
    "prod": "NODE_ENV=production tsx server.ts prod",
    "db": "tsx src/data/seed.ts"
  },
  "dependencies": {
    "@polka/parse": "1.0.0-next.28",
    "@polka/send": "1.0.0-next.28",
    "ajo": "0.1.29",
    "better-sqlite3": "^12.6.2",
    "clsx": "2.1.1",
    "kysely": "^0.28.10",
    "navaid": "1.2.0",
    "polka": "1.0.0-next.28",
    "sade": "1.8.1",
    "sirv": "3.0.2"
  },
  "devDependencies": {
    "@iconify-json/lucide": "1.2.85",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "25.0.9",
    "@unocss/preset-icons": "66.6.0",
    "@unocss/preset-wind4": "66.6.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "unocss": "66.6.0",
    "vite": "7.3.1"
  }
}
